<schemalist gettext-domain="gnome-shell-extension-crypto-tracker">
  <schema
      id="org.gnome.shell.extensions.crypto-tracker"
      path="/org/gnome/shell/extensions/crypto-tracker/">
    <key
        type="s"
        name="coins">
      <default>'{"coins":[{"id": "xxxx-xxxx-xxx-xxx1", "symbol":"BTC/USDT", "active": true, "title":"BTC","exchange":"Binance", "coingecko_id": ""}]}'</default>
      <description />
    </key>
    <key
        type='s'
        name='exchange'>
      <default>'Binance'</default>
    </key>
    <key
        type='i'
        name='update-interval'>
      <default>10</default>
    </key>
    <key type="s" name="panel-position">
      <default>'right'</default>
      <choices>
        <choice value="left" />
        <choice value="center" />
        <choice value="right" />
      </choices>
    </key>
    <key type="i" name="panel-box-index">
      <default>0</default>
    </key>
    <key type="i" name="font-size">
      <default>0</default>
    </key>
    <key type="s" name="panel-display-mode">
      <default>'static'</default>
      <choices>
        <choice value="static" />
        <choice value="ticker" />
        <choice value="marquee" />
      </choices>
    </key>
    <key type="i" name="ticker-interval">
      <default>5</default>
    </key>
  </schema>
</schemalist>